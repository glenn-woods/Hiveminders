# Normalize all text to LF in the repo, check out as LF
* text=auto eol=lf

# Godot source files
*.gd text eol=lf
*.uid text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.import text eol=lf
*.csv text eol=lf
*.md text eol=lf
*.godot text eol=lf

# Binary
*.png binary
*.jpg binary
*.ogg binary
*.res binary
*.ctex binary
